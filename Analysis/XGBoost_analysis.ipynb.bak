  {
   "cell_type": "markdown",
   "id": "492f81d1",
   "source": "## Model 2 — Feature-Eliminated XGBoost (95% Cumulative Importance)\n\nUsing Model 1's feature importance scores to select only the features that together explain **≥ 95%** of the model's predictive power. The remainder are dropped.  \nModel 2 is then retrained on this reduced feature set using the same temporal CV and search space.",
   "metadata": {}
  },
  {
   "cell_type": "code",
   "id": "6f789d85",
   "source": "# ── Feature selection: retain features up to 95% cumulative importance ────────\nprint(\"=\" * 80)\nprint(\"FEATURE IMPORTANCE — MODEL 1 (All 9 Features)\")\nprint(\"=\" * 80)\n\nfeature_importance_m1 = pd.DataFrame({\n    'Feature':    FEATURES,\n    'Importance': best_xgb.feature_importances_\n}).sort_values('Importance', ascending=False).reset_index(drop=True)\n\nfeature_importance_m1['Cumulative'] = feature_importance_m1['Importance'].cumsum()\n\nprint(f\"\\n{'Rank':<6} {'Feature':<20} {'Importance':<15} {'Cumulative'}\")\nprint(\"-\" * 58)\nfor i, row in feature_importance_m1.iterrows():\n    prev_cum = feature_importance_m1.iloc[i - 1]['Cumulative'] if i > 0 else 0\n    marker = \" ← 95% cut\" if row['Cumulative'] >= 0.95 and prev_cum < 0.95 else \"\"\n    print(f\"  {i+1:<4} {row['Feature']:<20} {row['Importance']:.4f}{'':>8} {row['Cumulative']:.4f}{marker}\")\n\n# Select minimum features to reach 95% cumulative importance\nn_features_95 = int((feature_importance_m1['Cumulative'] < 0.95).sum()) + 1\nFEATURES_M2   = feature_importance_m1.iloc[:n_features_95]['Feature'].tolist()\ndropped_feats  = feature_importance_m1.iloc[n_features_95:]['Feature'].tolist()\n\nprint(f\"\\n→ Retaining {len(FEATURES_M2)} features — cumulative importance: \"\n      f\"{feature_importance_m1.iloc[n_features_95-1]['Cumulative']:.2%}\")\nprint(f\"→ Dropped  : {dropped_feats}\")\n\n# ── Visualise ─────────────────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\ncolors = ['steelblue' if f in FEATURES_M2 else '#d62728'\n          for f in feature_importance_m1['Feature']]\naxes[0].barh(feature_importance_m1['Feature'], feature_importance_m1['Importance'],\n             color=colors, edgecolor='black', linewidth=0.5)\naxes[0].invert_yaxis()\naxes[0].set_xlabel('Importance Score', fontsize=11)\naxes[0].set_title('Feature Importance — Model 1\\n(blue = retained, red = dropped)',\n                  fontweight='bold', fontsize=12)\n\naxes[1].plot(range(1, len(feature_importance_m1) + 1),\n             feature_importance_m1['Cumulative'],\n             marker='o', linewidth=2, color='steelblue')\naxes[1].axhline(0.95, color='red', linestyle='--', linewidth=1.5, label='95% threshold')\naxes[1].axvline(n_features_95, color='green', linestyle='--', linewidth=1.5,\n                label=f'Cut at feature #{n_features_95}')\naxes[1].set_xlabel('Number of Features', fontsize=11)\naxes[1].set_ylabel('Cumulative Importance', fontsize=11)\naxes[1].set_title('Cumulative Feature Importance', fontweight='bold', fontsize=12)\naxes[1].legend(); axes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()",
   "metadata": {},
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "id": "25d02278",
   "source": "# ── Model 2: Train XGBoost on reduced feature set ─────────────────────────────\nprint(\"=\" * 80)\nprint(\"MODEL 2 — XGBOOST WITH FEATURE ELIMINATION (95% Importance Threshold)\")\nprint(\"=\" * 80)\nprint(f\"\\nFeatures used: {FEATURES_M2}\")\nprint(f\"Feature count: {len(FEATURES_M2)} (down from {len(FEATURES)})\")\n\nX_train_m2 = X_train[FEATURES_M2]\nX_test_m2  = X_test[FEATURES_M2]\n\nxgb_base_m2 = XGBClassifier(eval_metric='logloss', random_state=42, n_jobs=-1)\n\nxgb_search_m2 = RandomizedSearchCV(\n    estimator=xgb_base_m2,\n    param_distributions=param_dist,   # identical search space as Model 1\n    n_iter=50,\n    scoring='roc_auc',\n    cv=tscv,                          # same temporal CV\n    verbose=1,\n    random_state=42,\n    n_jobs=-1\n)\n\nxgb_search_m2.fit(X_train_m2, y_train)\nbest_xgb_m2 = xgb_search_m2.best_estimator_\n\nprint(\"\\nBest Parameters (Model 2):\")\nprint(xgb_search_m2.best_params_)\nprint(f\"\\nBest CV ROC-AUC: {xgb_search_m2.best_score_:.4f}\")\n\ny_pred_train_m2 = best_xgb_m2.predict(X_train_m2)\ny_pred_test_m2  = best_xgb_m2.predict(X_test_m2)\ny_pred_proba_m2 = best_xgb_m2.predict_proba(X_test_m2)[:, 1]\n\nprint(\"\\nTest Performance (Model 2 — Reduced Features):\")\nprint(classification_report(y_test, y_pred_test_m2))",
   "metadata": {},
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "id": "3815ba0d",
   "source": "# ── Model 2: Metrics ──────────────────────────────────────────────────────────\ntrain_acc_m2  = accuracy_score(y_train, y_pred_train_m2)\ntrain_prec_m2 = precision_score(y_train, y_pred_train_m2)\ntrain_rec_m2  = recall_score(y_train, y_pred_train_m2)\ntrain_f1_m2   = f1_score(y_train, y_pred_train_m2)\n\ntest_acc_m2   = accuracy_score(y_test, y_pred_test_m2)\ntest_prec_m2  = precision_score(y_test, y_pred_test_m2)\ntest_rec_m2   = recall_score(y_test, y_pred_test_m2)\ntest_f1_m2    = f1_score(y_test, y_pred_test_m2)\ntest_auc_m2   = roc_auc_score(y_test, y_pred_proba_m2)\n\nprint(\"=\" * 80)\nprint(\"MODEL 2 — PERFORMANCE METRICS\")\nprint(\"=\" * 80)\nprint(f\"\\n{'Metric':<20} {'Training':<15} {'Testing':<15}\")\nprint(\"-\" * 50)\nprint(f\"{'Accuracy':<20} {train_acc_m2:<15.4f} {test_acc_m2:<15.4f}\")\nprint(f\"{'Precision':<20} {train_prec_m2:<15.4f} {test_prec_m2:<15.4f}\")\nprint(f\"{'Recall':<20} {train_rec_m2:<15.4f} {test_rec_m2:<15.4f}\")\nprint(f\"{'F1-Score':<20} {train_f1_m2:<15.4f} {test_f1_m2:<15.4f}\")\nprint(f\"{'ROC-AUC':<20} {'N/A':<15} {test_auc_m2:<15.4f}\")\nprint(f\"\\nOverfitting Gap (Train - Test Accuracy): {train_acc_m2 - test_acc_m2:.4f}\")\n\nprint(\"\\n\" + \"=\" * 80)\nprint(\"DETAILED CLASSIFICATION REPORT (Model 2 — Test Set)\")\nprint(\"=\" * 80)\nprint(classification_report(y_test, y_pred_test_m2, target_names=['Negative', 'Positive']))",
   "metadata": {},
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "code",
   "id": "82c7b6a1",
   "source": "# ── Model 2: Confusion Matrix & ROC Curve ─────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\ncm_m2 = confusion_matrix(y_test, y_pred_test_m2)\nsns.heatmap(cm_m2, annot=True, fmt='d', cmap='Greens', ax=axes[0], cbar=False,\n            xticklabels=['Negative', 'Positive'],\n            yticklabels=['Negative', 'Positive'])\naxes[0].set_ylabel('True Label', fontsize=11)\naxes[0].set_xlabel('Predicted Label', fontsize=11)\naxes[0].set_title(f'Confusion Matrix — Model 2 ({len(FEATURES_M2)} Features)',\n                  fontweight='bold', fontsize=12)\ntn, fp, fn, tp = cm_m2.ravel()\naxes[0].text(0.5, -0.25, f'TN={tn}  FP={fp}\\nFN={fn}  TP={tp}',\n             transform=axes[0].transAxes, ha='center', fontsize=10, family='monospace')\n\nfpr_m2, tpr_m2, _ = roc_curve(y_test, y_pred_proba_m2)\nauc_m2 = auc(fpr_m2, tpr_m2)\n\naxes[1].plot(fpr_m2, tpr_m2, color='green', lw=2.5,\n             label=f'Model 2 ROC (AUC = {auc_m2:.4f})')\naxes[1].plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random Classifier')\naxes[1].set_xlim([0.0, 1.0]); axes[1].set_ylim([0.0, 1.05])\naxes[1].set_xlabel('False Positive Rate', fontsize=11)\naxes[1].set_ylabel('True Positive Rate', fontsize=11)\naxes[1].set_title('ROC Curve — Model 2', fontweight='bold', fontsize=12)\naxes[1].legend(loc='lower right'); axes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()",
   "metadata": {},
   "execution_count": null,
   "outputs": []
  },
  {
   "cell_type": "markdown",
   "id": "3661aac6",
   "source": "## Model Comparison — Model 1 vs Model 2\n\nHead-to-head evaluation of both models on the held-out test set.  \nThe best model is selected by **ROC-AUC** (most informative metric for imbalanced binary classification).",
   "metadata": {}
  },
  {
   "cell_type": "code",
   "id": "7e4f26ec",
   "source": "# ── Head-to-head comparison ───────────────────────────────────────────────────\nm1_acc   = accuracy_score(y_test,  y_pred_test)\nm1_prec  = precision_score(y_test, y_pred_test)\nm1_rec   = recall_score(y_test,    y_pred_test)\nm1_f1    = f1_score(y_test,        y_pred_test)\nm1_auc   = roc_auc_score(y_test,   y_pred_proba)\nm1_gap   = accuracy_score(y_train, y_pred_train) - m1_acc\n\nm2_acc   = test_acc_m2\nm2_prec  = test_prec_m2\nm2_rec   = test_rec_m2\nm2_f1    = test_f1_m2\nm2_auc   = test_auc_m2\nm2_gap   = train_acc_m2 - test_acc_m2\n\nprint(\"=\" * 80)\nprint(\"HEAD-TO-HEAD MODEL COMPARISON\")\nprint(\"=\" * 80)\nprint(f\"\\n{'Metric':<22} {'Model 1 (All 9)':<20} {'Model 2 (95% Imp.)':<20} {'Winner'}\")\nprint(\"-\" * 75)\n\ncomparisons = [\n    ('Accuracy',   m1_acc,  m2_acc,  True),\n    ('Precision',  m1_prec, m2_prec, True),\n    ('Recall',     m1_rec,  m2_rec,  True),\n    ('F1-Score',   m1_f1,   m2_f1,   True),\n    ('ROC-AUC',    m1_auc,  m2_auc,  True),\n]\nfor name, v1, v2, higher_is_better in comparisons:\n    winner = 'Model 1 ✓' if v1 > v2 else ('Model 2 ✓' if v2 > v1 else 'Tie')\n    print(f\"  {name:<20} {v1:<20.4f} {v2:<20.4f} {winner}\")\n\nprint(f\"\\n  {'Overfit Gap':<20} {m1_gap:<20.4f} {m2_gap:<20.4f} {'lower is better'}\")\nprint(f\"  {'Features Used':<20} {len(FEATURES):<20} {len(FEATURES_M2):<20}\")\n\nbest_name = f'Model 1 (All {len(FEATURES)} Features)' \\\n    if m1_auc >= m2_auc else f'Model 2 ({len(FEATURES_M2)} Features)'\nprint(f\"\\n{'='*80}\")\nprint(f\"  BEST MODEL (by ROC-AUC): {best_name}\")\nprint(f\"{'='*80}\")\n\n# ── Visualisations ────────────────────────────────────────────────────────────\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\nmetric_names = ['Accuracy', 'Precision', 'Recall', 'F1-Score', 'ROC-AUC']\nm1_vals = [m1_acc, m1_prec, m1_rec, m1_f1, m1_auc]\nm2_vals = [m2_acc, m2_prec, m2_rec, m2_f1, m2_auc]\nx = np.arange(len(metric_names))\nw = 0.35\n\naxes[0].bar(x - w/2, m1_vals, w, label=f'Model 1 — All {len(FEATURES)} Features',\n            color='steelblue', edgecolor='black')\naxes[0].bar(x + w/2, m2_vals, w, label=f'Model 2 — {len(FEATURES_M2)} Features (95% Imp.)',\n            color='#2ca02c', edgecolor='black')\naxes[0].set_xticks(x)\naxes[0].set_xticklabels(metric_names, rotation=15)\naxes[0].set_ylim(0, 1)\naxes[0].set_ylabel('Score')\naxes[0].set_title('Test Metrics — Model 1 vs Model 2', fontweight='bold', fontsize=12)\naxes[0].legend(); axes[0].grid(axis='y', alpha=0.3)\n\nfpr_m1, tpr_m1, _ = roc_curve(y_test, y_pred_proba)\nauc_m1_plot = auc(fpr_m1, tpr_m1)\n\naxes[1].plot(fpr_m1, tpr_m1, color='steelblue', lw=2.5,\n             label=f'Model 1 — {len(FEATURES)} features  (AUC = {auc_m1_plot:.4f})')\naxes[1].plot(fpr_m2, tpr_m2, color='#2ca02c', lw=2.5, linestyle='--',\n             label=f'Model 2 — {len(FEATURES_M2)} features  (AUC = {auc_m2:.4f})')\naxes[1].plot([0, 1], [0, 1], color='gray', lw=1.5, linestyle=':', label='Random Classifier')\naxes[1].set_xlim([0.0, 1.0]); axes[1].set_ylim([0.0, 1.05])\naxes[1].set_xlabel('False Positive Rate', fontsize=11)\naxes[1].set_ylabel('True Positive Rate', fontsize=11)\naxes[1].set_title('ROC Curves — Model 1 vs Model 2', fontweight='bold', fontsize=12)\naxes[1].legend(loc='lower right'); axes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()",
